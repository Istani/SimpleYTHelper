<h2>{{i18n "Videos"}}</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); grid-gap: 20px;">
    {{#each data.videos}}
        <div class="ui-widget-content ui-corner-all" style="padding: 10px;">
            <img src="{{thumbnail}}" style="width: 100%; border-radius: 4px;">
            <h4 style="margin: 10px 0 5px 0; height: 3em; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                {{title}}
            </h4>
            <div style="font-size: 0.9em; color: #666; margin-bottom: 5px;">
                <span class="service-{{service}}">{{service}}</span> | {{publishedAt}}
            </div>
            <div style="font-size: 0.85em; background: #f0f0f0; padding: 5px; border-radius: 4px; margin-bottom: 10px;">
                <strong>{{i18n "Views"}}:</strong> {{viewCount}} |
                <strong>Likes:</strong> {{likeCount}} |
                <strong>Comments:</strong> {{commentCount}}
            </div>
            <div style="font-size: 0.8em; height: 4.5em; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; color: #444;">
                {{description}}
            </div>
        </div>
    {{#else}}
        <p>No videos found.</p>
    {{/each}}
</div>
