<h2>Playlists</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); grid-gap: 20px;">
    {{#each data.playlists}}
        <div class="ui-widget-content ui-corner-all" style="padding: 10px;">
            <h4 style="margin: 0 0 10px 0;">{{title}}</h4>
            <div style="font-size: 0.9em; color: #666; margin-bottom: 5px;">
                <span class="service-{{service}}">{{service}}</span>
            </div>
            <p style="font-size: 0.85em; color: #444;">{{description}}</p>
            <div style="font-size: 0.8em; border-top: 1px solid #eee; padding-top: 5px; margin-top: 10px;">
                ID: {{pl_id}}
            </div>
        </div>
    {{#else}}
        <p>No playlists found.</p>
    {{/each}}
</div>
